{
  "manifest_version": "0.1",
  "name": "enigmapython-mcp",
  "version": "0.1.2",
  "description": "Exposes historically accurate Enigma machine emulators",
  "author": {
    "name": "Denis Maggiorotto"
  },
  "server": {
    "type": "binary",
    "entry_point": "docker",
    "mcp_config": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "enigmapython-mcp"
      ]
    }
  }
}